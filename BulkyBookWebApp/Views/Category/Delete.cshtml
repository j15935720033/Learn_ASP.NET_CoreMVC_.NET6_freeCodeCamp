@model Category

@{
    ViewData["Title"] = "刪除分類";
}

<form method="post" asp-action="Delete">

    <!-- 把分類 Id 傳給 DeletePost(int? id) -->
    <input asp-for="Id" type="hidden" />

    <div class="border border-secondary rounded p-4 mt-4 bg-dark">

        <div class="row pb-2">

            <h2 class="text-light fw-semibold">
                刪除分類
            </h2>

            <hr class="border-secondary opacity-100" />

        </div>

        <div class="mb-3">

            <label asp-for="Name"
                   class="form-label text-light fw-semibold">
            </label>

            <!-- disabled 表示只能看，不能修改 -->
            <input asp-for="Name"
                   class="form-control border-secondary bg-light text-dark"
                   disabled />

        </div>

        <div class="mb-3">

            <label asp-for="DisplayOrder"
                   class="form-label text-light fw-semibold">
            </label>

            <input asp-for="DisplayOrder"
                   class="form-control border-secondary bg-light text-dark"
                   disabled />

        </div>

        <div class="d-flex gap-2">

            <!-- 送出後會進入 CategoryController 的 DeletePost 方法 -->
            <button type="submit"
                    class="btn btn-danger fw-semibold"
                    style="width:150px">

                <i class="bi bi-trash3"></i>
                &nbsp;刪除

            </button>

            <a asp-controller="Category"
               asp-action="Index"
               class="btn btn-secondary fw-semibold"
               style="width:150px">

                <i class="bi bi-arrow-left-circle"></i>
                &nbsp;返回列表

            </a>

        </div>

    </div>

</form>